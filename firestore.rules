rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? userDoc().data.role : 'applicant'; }
    
    // Jurisdiction Helpers
    function myJuris() { return userDoc().data.jurisdiction; }
    function targetJuris() { return resource.data.jurisdiction; }
    function incomingJuris() { return request.resource.data.jurisdiction; }
    
    function isFounder() { return signedIn() && (role() == 'guildFounder' || role() == 'founder'); }
    function isCentralMaster() { return isFounder() || role() == 'centralGuildMaster'; }
    
    function isStateMaster() { 
      return isCentralMaster() || (role() == 'stateGuildMaster' && targetJuris().stateId == myJuris().stateId); 
    }
    
    function isCityMaster() {
      return isStateMaster() || (role() == 'cityGuildMaster' && targetJuris().cityId == myJuris().cityId);
    }
    
    function isReceptionist() {
      return isCityMaster() || (role() == 'receptionist' && targetJuris().cityId == myJuris().cityId);
    }

    function canWriteJuris(data) {
      return isFounder() || (
        data.jurisdiction.countryId == myJuris().countryId &&
        (role() == 'centralGuildMaster' || (
          data.jurisdiction.stateId == myJuris().stateId && (
            role() == 'stateGuildMaster' || (
              data.jurisdiction.cityId == myJuris().cityId && (role() == 'cityGuildMaster' || role() == 'receptionist')
            )
          )
        ))
      );
    }

    function owns(uid) { return signedIn() && request.auth.uid == uid; }
    function noPermanentDelete() { return false; }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if owns(userId);
      allow update: if owns(userId) || isCityMaster(); 
      allow delete: if noPermanentDelete();
    }

    match /organizations/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && canWriteJuris(request.resource.data);
      allow update: if signedIn() && canWriteJuris(resource.data);
      allow delete: if noPermanentDelete();
    }

    match /needs/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() && canWriteJuris(request.resource.data || resource.data);
      allow delete: if noPermanentDelete();
    }

    match /opportunities/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() && (canWriteJuris(request.resource.data || resource.data) || incomingJuris().applicants.hasAny([request.auth.uid]));
      allow delete: if noPermanentDelete();
    }

    match /quests/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() && canWriteJuris(request.resource.data || resource.data);
      allow delete: if noPermanentDelete();
    }

    match /questSubmissions/{id} {
      allow read: if signedIn() && (resource.data.memberId == request.auth.uid || isReceptionist());
      allow create: if signedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isReceptionist() || (signedIn() && resource.data.memberId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if noPermanentDelete();
    }

    match /outcomes/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() && canWriteJuris(request.resource.data || resource.data);
      allow delete: if noPermanentDelete();
    }

    match /verifications/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn() && canWriteJuris(request.resource.data || resource.data);
      allow delete: if noPermanentDelete();
    }

    match /revenueEvents/{id} {
      allow read: if isReceptionist();
      allow create, update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    match /knowledgeBase/{id} {
      allow read: if signedIn();
      allow create: if role() in ['member', 'contributor', 'receptionist'];
      allow update: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    match /activityLogs/{id} {
      allow read: if isCityMaster();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /notifications/{id} {
      allow read, update: if signedIn() && (resource.data.userId == request.auth.uid || isReceptionist());
      allow create: if isReceptionist();
      allow delete: if noPermanentDelete();
    }

    match /guildRegions/{id} {
      allow read: if signedIn();
      allow write: if isFounder();
    }

    match /guildStates/{id} {
      allow read: if signedIn();
      allow write: if isCentralMaster();
    }

    match /guildCities/{id} {
      allow read: if signedIn();
      allow write: if isStateMaster();
    }
  }
}
