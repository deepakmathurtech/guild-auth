rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function safeFile() { return request.resource.size < 20 * 1024 * 1024; }

    match /evidence/{uid}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && safeFile();
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && safeFile();
    }
  }
}
